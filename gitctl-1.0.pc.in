prefix=@PREFIX@
libdir=@LIBDIR@
includedir=@INCLUDEDIR@

Name: gitctl-@API_VERSION@
Description: kubectl-like CLI for managing git repositories across forges
Version: @VERSION@
Requires: glib-2.0 gobject-2.0 gio-2.0 gmodule-2.0 json-glib-1.0
Libs: -L${libdir} -lgitctl-@API_VERSION@
Cflags: -I${includedir}/gitctl
